mod {
    wizards.newContentElement.wizardItems.plugins {
        elements {
            bokunorecipe {
                iconIdentifier = bokunorecipe-plugin-bokunorecipe
                title = LLL:EXT:bokunorecipe/Resources/Private/Language/locallang_db.xlf:tx_bokunorecipe_bokunorecipe.name
